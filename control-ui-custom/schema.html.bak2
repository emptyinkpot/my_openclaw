<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>🗄️ 数据库表结构</title>
  <style>
    :root {
      --bg: #f6f8fa;
      --bg-secondary: #ffffff;
      --bg-tertiary: #f3f4f6;
      --border: #d0d7de;
      --border-light: #e5e7eb;
      --text: #24292f;
      --text-secondary: #57606a;
      --text-muted: #6e7781;
      --accent: #0969da;
      --success: #1a7f37;
      --warning: #9a6700;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 13px;
      padding: 20px;
    }
    .header {
      background: linear-gradient(90deg, #ddf4ff 0%, var(--bg-secondary) 100%);
      border: 1px solid #54aeff;
      border-radius: 8px;
      padding: 16px 20px;
      margin-bottom: 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .header h1 {
      font-size: 18px;
      margin-bottom: 6px;
    }
    .header p {
      font-size: 12px;
      color: var(--text-secondary);
    }
    .btn {
      padding: 6px 12px;
      border: 1px solid var(--border);
      background: var(--bg);
      border-radius: 4px;
      cursor: pointer;
      font-size: 12px;
    }
    .btn:hover {
      border-color: var(--accent);
      background: var(--bg-tertiary);
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
    }
    th {
      background: var(--bg-tertiary);
      padding: 12px;
      text-align: left;
      font-weight: 600;
      font-size: 12px;
      color: var(--text-secondary);
      border-bottom: 2px solid var(--border);
    }
    td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--border-light);
    }
    tr:hover {
      background: var(--bg-tertiary);
    }
    .badge-new {
      background: var(--accent);
      color: white;
      padding: 2px 6px;
      border-radius: 10px;
      font-size: 10px;
      margin-left: 6px;
    }
    .row-new {
      background: #fff8c5 !important;
    }
    .row-new:hover {
      background: #fae17d !important;
    }
    .legend {
      margin-top: 16px;
      padding: 12px;
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 6px;
      font-size: 12px;
      color: var(--text-secondary);
    }
    .loading {
      text-align: center;
      padding: 60px;
      color: var(--text-muted);
    }
    .error {
      background: #ffebe9;
      border: 1px solid #ff8182;
      color: #cf222e;
      padding: 16px;
      border-radius: 6px;
      margin: 20px 0;
    }
  </style>
</head>
<body>
  <div class="header">
    <div>
      <h1>🗄️ 数据库表结构</h1>
      <p>表: chapters | 数据库: cloudbase-4glvyyq9f61b19cd (MySQL) - <span id="status">加载中...</span></p>
    </div>
    <button class="btn" onclick="loadSchema()">🔄 刷新</button>
  </div>

  <div id="content">
    <div class="loading">⏳ 正在从 MySQL 加载表结构...</div>
  </div>

  <script>
    const API_BASE = '/novel/api';
    
    async function loadSchema() {
      const content = document.getElementById('content');
      const status = document.getElementById('status');
      
      try {
        content.innerHTML = '<div class="loading">⏳ 正在从 MySQL 加载表结构...</div>';
        
        const res = await fetch(`${API_BASE}/schema`);
        const result = await res.json();
        
        if (!result.success) {
          throw new Error(result.error);
        }
        
        const columns = result.data;
        const newCount = columns.filter(c => c.isNew).length;
        
        status.textContent = `共 ${columns.length} 个字段，其中 ${newCount} 个新增`;
        
        content.innerHTML = `
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>字段名</th>
                <th>类型</th>
                <th>可空</th>
                <th>默认值</th>
                <th>额外</th>
                <th>说明</th>
              </tr>
            </thead>
            <tbody>
              ${columns.map((col, idx) => `
                <tr class="${col.isNew ? 'row-new' : ''}">
                  <td>${idx + 1}</td>
                  <td>
                    <strong>${col.Field}</strong>
                    ${col.isNew ? '<span class="badge-new">NEW</span>' : ''}
                  </td>
                  <td>${col.Type}</td>
                  <td>${col.Null === 'YES' ? '✓' : '✗'}</td>
                  <td>${col.Default || 'NULL'}</td>
                  <td>${col.Extra || '-'}</td>
                  <td>${getComment(col.Field)}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
          
          <div class="legend">
            <strong>图例:</strong> 🟨 黄色背景 = 新增字段 (共 ${newCount} 个) | 
            🔵 NEW 标签 = 新增标记 | 
            ✓ 可空 | ✗ 非空
          </div>
        `;
      } catch (err) {
        content.innerHTML = `<div class="error">❌ 加载失败: ${err.message}</div>`;
        status.textContent = '加载失败';
      }
    }
    
    function getComment(field) {
      const comments = {
        'id': '主键ID',
        'work_id': '作品ID',
        'volume_number': '卷号',
        'chapter_number': '章节号',
        'title': '标题',
        'content': '原始内容',
        'word_count': '字数统计',
        'status': '章节状态',
        'created_at': '创建时间',
        'updated_at': '更新时间',
        'audit_status': '✨ 审核状态',
        'audit_issues': '✨ 审核问题',
        'polish_status': '✨ 润色状态',
        'polished_content': '✨ 润色后内容',
        'polished_at': '✨ 润色时间',
        'audited_at': '✨ 审核时间',
        'publish_status': '✨ 发布状态',
        'published_at': '✨ 发布时间',
        'published_platform': '✨ 发布平台'
      };
      return comments[field] || '-';
    }
    
    // 自动加载
    loadSchema();
  </script>
</body>
</html>
