{
  "id": "ai-model-hub",
  "name": "AI模型管理中心",
  "description": "集成Unsloth微调、Ollama/vLLM本地部署、AST沙盒安全的AI模型管理模块",
  "version": "1.0.0",
  "routes": {
    "path": "/ai-hub",
    "target": "http://localhost:5100",
    "ws": true
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "localModels": {
        "type": "object",
        "properties": {
          "ollama": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "host": { "type": "string", "default": "http://localhost:11434" },
              "defaultModel": { "type": "string", "default": "llama3.2" }
            }
          },
          "vllm": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "host": { "type": "string", "default": "http://localhost:8000" },
              "model": { "type": "string" }
            }
          }
        }
      },
      "fineTuning": {
        "type": "object",
        "properties": {
          "unsloth": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "outputDir": { "type": "string", "default": "./models/fine-tuned" },
              "defaultConfig": {
                "type": "object",
                "properties": {
                  "r": { "type": "number", "default": 16 },
                  "loraAlpha": { "type": "number", "default": 16 },
                  "epochs": { "type": "number", "default": 3 }
                }
              }
            }
          }
        }
      },
      "sandbox": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "provider": { "type": "string", "enum": ["e2b", "local", "docker"], "default": "local" },
          "astCheck": { "type": "boolean", "default": true },
          "blockedModules": {
            "type": "array",
            "default": ["os", "subprocess", "socket", "requests"]
          }
        }
      }
    }
  }
}
