# 网站自动化配置
# 请根据你要自动化的网站填写以下信息

# 网站登录页 URL
SITE_URL=https://your-site.com/login

# 登录凭据（建议设置环境变量而不是写在这里）
# export SITE_USERNAME="your_username"
# export SITE_PASSWORD="your_password"

# AI 写作页面 URL（如果不是从登录页跳转）
AI_WRITE_URL=https://your-site.com/ai-write

# CSS 选择器配置（需要根据实际网站开发者工具获取）
# 登录表单
USERNAME_SELECTOR=input[name="username"]
PASSWORD_SELECTOR=input[name="password"]
LOGIN_BUTTON_SELECTOR=button[type="submit"]

# AI 写作页面
PROMPT_INPUT_SELECTOR=textarea.ai-input
GENERATE_BUTTON_SELECTOR=button.generate-btn
RESULT_SELECTOR=.article-content

# 等待时间配置（毫秒）
LOGIN_WAIT=3000
GENERATE_WAIT=30000
