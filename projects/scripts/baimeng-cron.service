[Unit]
Description=白梦写作网定时任务
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/workspace/projects
ExecStart=/usr/bin/node scripts/baimeng_cron.js daily
StandardOutput=append:/workspace/projects/output/baimeng_cron.log
StandardError=append:/workspace/projects/output/baimeng_cron.log

[Install]
WantedBy=multi-user.target
