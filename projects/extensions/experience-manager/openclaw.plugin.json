{
  "id": "experience-manager",
  "name": "经验积累系统",
  "description": "自我学习与经验积累模块，记录问题解决经验",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "cloudSync": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": false },
          "endpoint": { "type": "string" },
          "pathPrefix": { "type": "string", "default": "/api/experience-cloud" },
          "token": { "type": "string" },
          "namespace": { "type": "string", "default": "experience-manager" },
          "timeoutMs": { "type": "number", "default": 8000 },
          "syncNotes": { "type": "boolean", "default": true }
        }
      },
      "form": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["problem_solving", "feature_dev", "bug_fix", "optimization", "learning", "refactoring"]
          },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "problem": { "type": "string" },
          "rootCause": { "type": "string" },
          "solution": { "type": "string" },
          "experienceApplied": {
            "type": "array",
            "items": { "type": "string" }
          },
          "experienceGained": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "difficulty": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          },
          "xpGained": { "type": "integer" },
          "source": {
            "type": "object",
            "additionalProperties": true
          },
          "verification": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
