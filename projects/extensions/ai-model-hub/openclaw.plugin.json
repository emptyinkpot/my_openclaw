{
  "id": "ai-model-hub",
  "name": "AI模型管理中心",
  "description": "集成本地模型、模型微调与安全沙盒的 AI 模块",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "localModels": {
        "type": "object",
        "properties": {
          "ollama": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": true },
              "host": { "type": "string", "default": "http://127.0.0.1:11434" },
              "defaultModel": { "type": "string", "default": "qwen2.5:7b" }
            }
          },
          "vllm": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "host": { "type": "string", "default": "http://127.0.0.1:8000" },
              "model": { "type": "string" }
            }
          },
          "scanDir": {
            "type": "string"
          }
        }
      },
      "fineTuning": {
        "type": "object",
        "properties": {
          "unsloth": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean", "default": false },
              "outputDir": { "type": "string" },
              "defaultConfig": {
                "type": "object",
                "properties": {
                  "r": { "type": "number", "default": 16 },
                  "loraAlpha": { "type": "number", "default": 16 },
                  "epochs": { "type": "number", "default": 3 },
                  "learningRate": { "type": "number", "default": 0.0002 },
                  "batchSize": { "type": "number", "default": 2 }
                }
              }
            }
          }
        }
      },
      "sandbox": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "provider": { "type": "string", "enum": ["e2b", "local", "docker"], "default": "local" },
          "astCheck": { "type": "boolean", "default": true },
          "blockedModules": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
