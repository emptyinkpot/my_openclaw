{"type":"message","id":"64f9fb98","parentId":"5f7839e6","timestamp":"2026-03-18T12:08:43.706Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"好的，我已经了解了项目规范。现在我需要执行番茄批量发布任务。让我查看一下这个脚本文件的内容，以便了解它的功能和如何正确执行。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"019d00d9224a7e96e824b820ddd27450","name":"read","arguments":{"file_path":"/workspace/projects/auto-scripts/task-planner/scripts/auto-publish-all.js"}}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":4894,"output":84,"cacheRead":17536,"cacheWrite":0,"totalTokens":22514,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773835713717}}
{"type":"message","id":"39f9fcc0","parentId":"64f9fb98","timestamp":"2026-03-18T12:08:43.715Z","message":{"role":"toolResult","toolCallId":"019d00d9224a7e96e824b820ddd27450","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * 番茄多账号多作品自动发布\n * \n * 每天为所有账号的所有作品自动发布2章\n * 用法：node bin/auto-publish-all.js\n */\n\nconst { execSync } = require('child_process');\nconst path = require('path');\nconst fs = require('fs');\nconst { ACCOUNTS, PUBLISH_CONFIG } = require('../config/fanqie-accounts');\n\n// 引入飞书通知\nlet FeishuNotifier;\ntry {\n  const notifier = require('../core/notification/FeishuNotifier');\n  FeishuNotifier = notifier.FeishuNotifier;\n} catch (e) {\n  console.log('⚠ 飞书通知模块未加载');\n}\n\nconst sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));\n\n/**\n * 执行单作品发布\n */\nasync function publishWork(account, work, chapterNum) {\n  const publishScript = path.join(__dirname, 'publish-to-fanqie.js');\n  const browserDir = path.resolve(account.browserDir);\n  \n  console.log(`\\n📖 [${account.name}] ${work.name} - 第${chapterNum}章`);\n  console.log(`   浏览器: ${browserDir}`);\n  \n  try {\n    // 设置环境变量指定浏览器目录\n    const env = {\n      ...process.env,\n      FANQIE_BROWSER_DIR: browserDir,\n    };\n    \n    execSync(`node \"${publishScript}\" ${work.index}`, {\n      stdio: 'inherit',\n      timeout: 10 * 60 * 1000, // 10分钟超时\n      env,\n    });\n    \n    return {\n      account: account.name,\n      work: work.name,\n      chapter: chapterNum,\n      status: 'success',\n      time: new Date().toISOString(),\n    };\n  } catch (e) {\n    return {\n      account: account.name,\n      work: work.name,\n      chapter: chapterNum,\n      status: 'failed',\n      error: e.message,\n      time: new Date().toISOString(),\n    };\n  }\n}\n\n/**\n * 发送通知\n */\nasync function sendNotification(results) {\n  if (!FeishuNotifier || !process.env.FEISHU_APP_ID) {\n    return;\n  }\n  \n  try {\n    const notifier = new FeishuNotifier();\n    \n    const success = results.filter(r => r.status === 'success').length;\n    const failed = results.filter(r => r.status === 'failed').length;\n    \n    const details = results.map(r => {\n      const icon = r.status === 'success' ? '✅' : '❌';\n      return `${icon} [${r.account}] ${r.work} 第${r.chapter}章`;\n    }).join('\\n');\n    \n    await notifier.sendMessage(\n      `📊 番茄自动发布完成\\n\\n` +\n      `✅ 成功: ${success} 章\\n` +\n      `❌ 失败: ${failed} 章\\n` +\n      `⏰ 时间: ${new Date().toLocaleString('zh-CN')}\\n\\n` +\n      `详情:\\n${details}\\n\\n` +\n      `---\\nOpenClaw 自动发布系统`\n    );\n    \n    console.log('\\n📱 通知已发送');\n  } catch (e) {\n    console.log('⚠ 通知发送失败:', e.message);\n  }\n}\n\n/**\n * 主流程\n */\nasync function main() {\n  console.log('\\n' + '='.repeat(60));\n  console.log('🚀 番茄多账号自动发布任务');\n  console.log('='.repeat(60));\n  \n  console.log(`\\n📋 配置:`);\n  console.log(`   账号数量: ${ACCOUNTS.length}`);\n  console.log(`   每账号作品: ${ACCOUNTS.map(a => a.works.length).join(', ')}`);\n  console.log(`   每作品每天: ${PUBLISH_CONFIG.chaptersPerWork}章`);\n  console.log(`   章节间隔: ${PUBLISH_CONFIG.chapterInterval}分钟`);\n  console.log(`   作品间隔: ${PUBLISH_CONFIG.workInterval}分钟`);\n  console.log(`   账号间隔: ${PUBLISH_CONFIG.accountInterval}分钟\\n`);\n  \n  // 计算总章节数\n  const totalWorks = ACCOUNTS.reduce((sum, a) => sum + a.works.length, 0);\n  const totalChapters = totalWorks * PUBLISH_CONFIG.chaptersPerWork;\n  \n  console.log(`📊 预计发布: ${totalChapters} 章\\n`);\n  \n  const results = [];\n  let completedCount = 0;\n  \n  // 遍历所有账号\n  for (let accountIndex = 0; accountIndex < ACCOUNTS.length; accountIndex++) {\n    const account = ACCOUNTS[accountIndex];\n    \n    console.log(`\\n${'='.repeat(60)}`);\n    console.log(`👤 [${accountIndex + 1}/${ACCOUNTS.length}] 账号: ${account.name}`);\n    console.log(`${'='.repeat(60)}`);\n    \n    // 确保浏览器目录存在\n    if (!fs.existsSync(account.browserDir)) {\n      fs.mkdirSync(account.browserDir, { recursive: true });\n      console.log(`   创建浏览器目录: ${account.browserDir}`);\n    }\n    \n    // 遍历该账号的所有作品\n    for (let workIndex = 0; workIndex < account.works.length; workIndex++) {\n      const work = account.works[workIndex];\n      \n      console.log(`\\n📚 [${workIndex + 1}/${account.works.length}] 作品: ${work.name}`);\n      \n      // 发布配置的章节数\n      for (let chapterNum = 1; chapterNum <= PUBLISH_CONFIG.chaptersPerWork; chapterNum++) {\n        completedCount++;\n        \n        console.log(`\\n📝 进度: ${completedCount}/${totalChapters} 章`);\n        \n        const result = await publishWork(account, work, chapterNum);\n        results.push(result);\n        \n        // 章节间隔（如果不是最后一个章节）\n        if (chapterNum < PUBLISH_CONFIG.chaptersPerWork) {\n          console.log(`⏳ 等待 ${PUBLISH_CONFIG.chapterInterval} 分钟...`);\n          await sleep(PUBLISH_CONFIG.chapterInterval * 60 * 1000);\n        }\n      }\n      \n      // 作品间隔（如果不是最后一个作品）\n      if (workIndex < account.works.length - 1) {\n        console.log(`⏳ 作品间隔，等待 ${PUBLISH_CONFIG.workInterval} 分钟...`);\n        await sleep(PUBLISH_CONFIG.workInterval * 60 * 1000);\n      }\n    }\n    \n    // 账号间隔（如果不是最后一个账号）\n    if (accountIndex < ACCOUNTS.length - 1) {\n      console.log(`⏳ 账号间隔，等待 ${PUBLISH_CONFIG.accountInterval} 分钟...`);\n      await sleep(PUBLISH_CONFIG.accountInterval * 60 * 1000);\n    }\n  }\n  \n  // 打印汇总\n  console.log('\\n' + '='.repeat(60));\n  console.log('📊 发布任务完成');\n  console.log('='.repeat(60));\n  \n  const success = results.filter(r => r.status === 'success').length;\n  const failed = results.filter(r => r.status === 'failed').length;\n  \n  console.log(`\\n✅ 成功: ${success} 章`);\n  console.log(`❌ 失败: ${failed} 章`);\n  console.log(`📊 总计: ${results.length} 章`);\n  \n  // 打印失败详情\n  const failedResults = results.filter(r => r.status === 'failed');\n  if (failedResults.length > 0) {\n    console.log(`\\n❌ 失败详情:`);\n    failedResults.forEach(r => {\n      console.log(`   [${r.account}] ${r.work} 第${r.chapter}章: ${r.error}`);\n    });\n  }\n  \n  // 发送通知\n  await sendNotification(results);\n  \n  console.log('\\n✅ 任务结束\\n');\n  \n  // 如果有失败，返回错误码\n  if (failed > 0) {\n    process.exit(1);\n  }\n}\n\nmain().catch(e => {\n  console.error('\\n✗ 任务失败:', e.message);\n  process.exit(1);\n});\n"}],"isError":false,"timestamp":1773835723713}}
