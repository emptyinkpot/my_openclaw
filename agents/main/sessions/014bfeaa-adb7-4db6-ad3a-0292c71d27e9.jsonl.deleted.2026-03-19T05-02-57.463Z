{"type":"message","id":"aa3f110f","parentId":"dbd029b9","timestamp":"2026-03-18T05:01:45.848Z","message":{"role":"toolResult","toolCallId":"019cff523c6bb3637339799ef8225a2b","toolName":"read","content":[{"type":"text","text":"/**\n * 番茄小说多账号多作品配置\n * \n * 支持多个番茄账号，每个账号有多部作品\n * 每部作品每天自动发布2章\n */\n\nconst ACCOUNTS = [\n  {\n    id: 'account_1',\n    name: '主账号',\n    browserDir: '/workspace/projects/browser/fanqie-account-1',\n    works: [\n      { index: 1, name: '转生病弱王女的我被宿敌圈养了' },\n      { index: 2, name: '枪与凋零之花' },\n      { index: 3, name: '咳血少女与前世宿敌的百合维新' },\n      { index: 4, name: '无纪年王国' },\n      { index: 5, name: '转生王女因为太病弱被宿敌圈养了' },\n      { index: 6, name: '近卫文子小姐请优雅地败北吧！' },\n    ]\n  },\n  {\n    id: 'account_2',\n    name: '小号',\n    browserDir: '/workspace/projects/browser/fanqie-account-2',\n    works: [\n      { index: 1, name: '变身S级魅魔后，被坏女人包围了' },\n      { index: 2, name: '原来我是爱丽丝' },\n    ]\n  },\n];\n\n// 发布配置\nconst PUBLISH_CONFIG = {\n  // 每部作品每天发布的章节数\n  chaptersPerWork: 2,\n  \n  // 章节发布间隔（分钟）\n  chapterInterval: 10,\n  \n  // 作品发布间隔（分钟）\n  workInterval: 30,\n  \n  // 账号发布间隔（分钟）\n  accountInterval: 60,\n};\n\nmodule.exports = { ACCOUNTS, PUBLISH_CONFIG };\n"}],"isError":false,"timestamp":1773810105841}}
