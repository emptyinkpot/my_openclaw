{"type":"message","id":"7dfad3bb","parentId":"a0001e1e","timestamp":"2026-03-18T12:14:37.607Z","message":{"role":"toolResult","toolCallId":"019d00de8801e4e2f4f07a6bd2269ad4","toolName":"read","content":[{"type":"text","text":"  // 发布成功判断\n  const successIndicators = [\n    pageUrl.includes('book-manage'),\n    pageUrl.includes('chapter-manage'),\n    pageContent.includes('发布成功'),\n    pageContent.includes('章节管理'),\n    await page.locator('text=发布成功').count() > 0,\n    await page.locator('text=章节管理').count() > 0,\n  ];\n  \n  const successCount = successIndicators.filter(Boolean).length;\n  const isPublished = successCount >= 2; // 至少满足2个条件才算成功\n  \n  console.log('\\n  === 发布验证 ===');\n  console.log(`  当前URL: ${pageUrl}`);\n  console.log(`  成功指标: ${successCount}/${successIndicators.length}`);\n  console.log(`  指标详情: book-manage=${successIndicators[0]}, chapter-manage=${successIndicators[1]}, 发布成功文本=${successIndicators[2]}, 章节管理文本=${successIndicators[3]}, 发布章节成功=${successIndicators[4]}`);\n  \n  if (isPublished) {\n    console.log('\\n✅ 发布成功！');\n    \n    // 记录操作\n    recordAction({\n      script: 'publish-to-fanqie',\n      workId: `work-${workIndex}`,\n      workName: workTitle,\n      chapterNum: chapterNum,\n      chapterTitle: finalTitle,\n      action: '发布',\n      result: 'success',\n      steps: publishSteps\n    });\n    \n    // 发送飞书通知\n    if (feishu) {\n      try {\n        await feishu.notifyPublishSuccess(workTitle, chapterNum, chapterTitle, wordCount, `https://fanqienovel.com/main/writer/book-manage`);\n        console.log('  📱 飞书通知已发送');\n      } catch (e) {\n        console.log('  ⚠ 飞书通知发送失败:', e.message);\n      }\n    }\n    \n    // 显示提示\n    showLastAction('publish-to-fanqie');\n  } else {\n    console.log('\\n❌ 发布失败！');\n    console.log('  发布步骤:', JSON.stringify(publishSteps, null, 2));\n    \n    // 发送飞书失败通知\n    if (feishu) {\n      try {\n        const errorReason = publishSteps.find(s => !s.success)?.error || '发布验证失败';\n        await feishu.notifyPublishFailed(workTitle, chapterNum, errorReason);\n        console.log('  📱 飞书失败通知已发送');\n      } catch (e) {\n        console.log('  ⚠ 飞书通知发送失败:', e.message);\n      }\n    }\n    \n    // 截图保存失败状态\n    const failScreenshot = path.join(CONFIG.screenshotDir, 'fanqie-publish-failed.png');\n    await page.screenshot({ path: failScreenshot, fullPage: true });\n    console.log(`  失败截图: ${failScreenshot}`);\n    \n    // 记录失败\n    recordAction({\n      script: 'publish-to-fanqie',\n      workId: `work-${workIndex}`,\n      workName: workTitle,\n      chapterNum: chapterNum,\n      chapterTitle: finalTitle,\n      action: '发布',\n      result: 'failed',\n      steps: publishSteps,\n      reason: '发布验证失败'\n    });\n    \n    // 截图后退出\n    const screenshotPath = path.join(CONFIG.screenshotDir, 'fanqie-published.png');\n    await page.screenshot({ path: screenshotPath });\n    console.log(`截图: ${screenshotPath}`);\n    \n    await wait(2000);\n    await fanqieBrowser.close();\n    closeDb(); // 关闭数据库连接\n    \n    // 返回非0退出码\n    process.exit(1);\n  }\n  \n  const screenshotPath = path.join(CONFIG.screenshotDir, 'fanqie-published.png');\n  await page.screenshot({ path: screenshotPath });\n  console.log(`截图: ${screenshotPath}`);\n  \n  await wait(3000);\n  await fanqieBrowser.close();\n  closeDb(); // 关闭数据库连接\n}\n\nmain().catch(e => { \n  console.error('✗ 错误:', e.message); \n  closeDb(); // 确保错误时也关闭数据库\n  process.exit(1); \n});\n"}],"isError":false,"timestamp":1773836077604}}
