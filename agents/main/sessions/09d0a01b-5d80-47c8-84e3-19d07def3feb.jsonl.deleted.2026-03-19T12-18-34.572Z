{"type":"message","id":"187d17f0","parentId":"a224e3a3","timestamp":"2026-03-18T12:14:32.252Z","message":{"role":"toolResult","toolCallId":"019d00de73b6a7c4a52e9b44858d0597","toolName":"read","content":[{"type":"text","text":"// ============================================================\n\n// 引入统一配置\ntry {\n  const { BROWSER_CONFIG, AUTH_CONFIG } = require('../config');\n} catch (e) {\n  // 备用配置\n  var BROWSER_CONFIG = {\n    baimeng: '/workspace/projects/browser/baimeng-unified',\n    fanqie: '/workspace/projects/browser/fanqie-unified'\n  };\n  var AUTH_CONFIG = {\n    baimengBackup: '/workspace/projects/cookies-accounts/baimeng-20260314-111942.json'\n  };\n}\n\n// 如果没有定义 AUTH_CONFIG 或 baimengBackup，使用默认值\nif (typeof AUTH_CONFIG === 'undefined' || !AUTH_CONFIG.baimengBackup) {\n  AUTH_CONFIG = {\n    baimengBackup: '/workspace/projects/cookies-accounts/baimeng-20260314-111942.json'\n  };\n}\n\nconst CONFIG = {\n  // 浏览器数据目录 - 支持环境变量指定（多账号隔离）\n  fanqieDir: process.env.FANQIE_BROWSER_DIR || \n             (BROWSER_CONFIG ? BROWSER_CONFIG.fanqie : '/workspace/projects/browser/fanqie-unified'),\n  baimengDir: process.env.BAIMENG_BROWSER_DIR || \n              (BROWSER_CONFIG ? BROWSER_CONFIG.baimeng : '/workspace/projects/browser/baimeng-unified'),\n  // 登录备份文件 - 使用绝对路径确保正确\n  loginBackup: (AUTH_CONFIG && AUTH_CONFIG.baimengBackup) \n    ? AUTH_CONFIG.baimengBackup \n    : '/workspace/projects/cookies-accounts/baimeng-20260314-111942.json',\n  // 截图目录\n  screenshotDir: '/tmp',\n  // 视口大小\n  viewport: { width: 1400, height: 850 },\n  // 最小字数阈值\n  minContentLength: 50\n};\n\nconst wait = (ms) => new Promise(r => setTimeout(r, ms));\n\n// ============================================================\n// 中文数字转换\n// ============================================================\n\nfunction chineseToNum(str) {\n  if (/^\\d+$/.test(str)) return parseInt(str);\n  const nums = { '零': 0, '一': 1, '二': 2, '三': 3, '四': 4, '五': 5, '六': 6, '七': 7, '八': 8, '九': 9 };\n  const units = { '十': 10, '百': 100, '千': 1000 };\n  let result = 0, temp = 0;\n  for (let i = 0; i < str.length; i++) {\n    const c = str[i];\n    if (nums[c] !== undefined) temp = temp * 10 + nums[c];\n    else if (units[c] !== undefined) {\n      if (temp === 0 && i === 0) temp = 1;\n      result += temp * units[c];\n      temp = 0;\n    }\n  }\n  return result + temp;\n}\n\nfunction numToChinese(n) {\n  const digits = ['零', '一', '二', '三', '四', '五', '六', '七', '八', '九'];\n  if (n <= 10) return ['零', '一', '二', '三', '四', '五', '六', '七', '八', '九', '十'][n];\n  if (n < 20) return '十' + digits[n % 10];\n  if (n < 100) return digits[Math.floor(n / 10)] + '十' + (n % 10 ? digits[n % 10] : '');\n  return String(n);\n}\n\nfunction parseChapterNumber(input) {\n  if (typeof input === 'number') return input;\n  const str = input.toString().trim();\n  if (/^\\d+$/.test(str)) return parseInt(str, 10);\n  const match = str.match(/第([零一二三四五六七八九十百千\\d]+)章/);\n  if (match) return chineseToNum(match[1]);\n  if (/^[零一二三四五六七八九十百千]+$/.test(str)) return chineseToNum(str);\n  const numMatch = str.match(/(\\d+)/);\n  if (numMatch) return parseInt(numMatch[1], 10);\n  return 0;\n}\n\nfunction similarity(a, b) {\n  if (a === b) return 1;\n  const s1 = a.trim().toLowerCase();\n  const s2 = b.trim().toLowerCase();\n  if (s1 === s2) return 1;\n  if (s1.length === 0 || s2.length === 0) return 0;\n  if (s1.includes(s2) || s2.includes(s1)) return 0.8;\n  \n  const longer = s1.length > s2.length ? s1 : s2;\n  const shorter = s1.length > s2.length ? s2 : s1;\n  const matrix = Array(longer.length + 1).fill(null).map(() => Array(shorter.length + 1).fill(0));\n  for (let i = 0; i <= longer.length; i++) matrix[i][0] = i;\n  for (let j = 0; j <= shorter.length; j++) matrix[0][j] = j;\n  for (let i = 1; i <= longer.length; i++) {\n    for (let j = 1; j <= shorter.length; j++) {\n      matrix[i][j] = longer[i - 1] === shorter[j - 1] \n\n[1255 more lines in file. Use offset=201 to continue.]"}],"isError":false,"timestamp":1773836072249}}
