tle.split('\\n')[0].trim();\n    \n    const info = await card.evaluate(el => {\n      const text = el.innerText;\n      const lines = text.split('\\n').map(l => l.trim()).filter(l => l);\n      return lines.slice(0, 8);\n    });\n    \n    console.log(\\`\\${i+1}. \\${titleText}\\`);\n    console.log(\\`   \\${info.slice(1, 6).join(' | ')}\\`);\n    console.log();\n  }\n  \n  await browser.close();\n}\n\ncheckAccount2().catch(console.error);\n\" 2>&1","timeout":60}}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":868,"output":871,"cacheRead":50944,"cacheWrite":0,"totalTokens":52683,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773810307783}}
