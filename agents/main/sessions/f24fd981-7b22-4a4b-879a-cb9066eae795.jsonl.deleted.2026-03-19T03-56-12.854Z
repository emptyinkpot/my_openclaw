{"type":"message","id":"34de1add","parentId":"01eb9ba6","timestamp":"2026-03-18T03:58:59.228Z","message":{"role":"toolResult","toolCallId":"call_function_9w37fddfcsoz_1","toolName":"read","content":[{"type":"text","text":"    });\n    console.log('📱 飞书通知已启用');\n  }\n  \n  console.log(`\\n📚 发布${workIndex ? '第 ' + workIndex + ' 部' : '\"' + workName + '\"'}作品\\n`);\n  \n  // ========== Step 1: 番茄获取最新章节 ==========\n  console.log('【1/4】番茄 - 获取最新章节');\n  \n  cleanLocks(CONFIG.fanqieDir);\n  const fanqieBrowser = await chromium.launchPersistentContext(CONFIG.fanqieDir, {\n    headless: false, channel: 'chrome', viewport: CONFIG.viewport, args: ['--no-sandbox']\n  });\n  let page = fanqieBrowser.pages()[0];\n  \n  await page.goto('https://fanqienovel.com/main/writer/book-manage', { waitUntil: 'domcontentloaded' });\n  \n  try {\n    await page.waitForSelector('[id^=\"long-article-table-item-\"]', { state: 'visible', timeout: 10000 });\n  } catch (e) {\n    console.log('  ✗ 未找到作品列表，可能需要登录');\n    await fanqieBrowser.close();\n    process.exit(1);\n  }\n  \n  await closePopups(page);\n  \n  // 检查作品数量\n  const cardCount = await page.locator('[id^=\"long-article-table-item-\"]').count();\n  \n  // 如果按名称查找，先找到对应的序号\n  if (workName) {\n    workIndex = 0;\n    for (let i = 0; i < cardCount; i++) {\n      const card = page.locator('[id^=\"long-article-table-item-\"]').nth(i);\n      const title = (await card.locator('.hoverup').first().innerText()).split('\\n')[0].trim();\n      // 精确匹配或包含匹配\n      if (title === workName || title.includes(workName) || workName.includes(title)) {\n        workIndex = i + 1;\n        console.log(`  ✓ 找到作品: ${title} (序号 ${workIndex})`);\n        break;\n      }\n    }\n    if (!workIndex) {\n      console.log(`  ✗ 未找到作品: ${workName}`);\n      await fanqieBrowser.close();\n      process.exit(1);\n    }\n  }\n  \n  if (workIndex > cardCount) {\n    console.log(`  ✗ 作品序号超出范围 (1-${cardCount})`);\n    await fanqieBrowser.close();\n    process.exit(1);\n  }\n  \n  const card = page.locator('[id^=\"long-article-table-item-\"]').nth(workIndex - 1);\n  const workTitle = (await card.locator('.hoverup').first().innerText()).split('\\n')[0].trim();\n  console.log(`  ✓ 作品: ${workTitle}`);\n  \n\n[521 more lines in file. Use offset=880 to continue.]"}],"isError":false,"timestamp":1773806339222}}
