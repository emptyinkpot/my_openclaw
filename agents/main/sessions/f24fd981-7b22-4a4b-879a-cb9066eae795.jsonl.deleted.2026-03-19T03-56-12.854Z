{"type":"message","id":"bf525507","parentId":"e39a3bbb","timestamp":"2026-03-18T03:59:11.260Z","message":{"role":"toolResult","toolCallId":"call_function_mx1imaqg1w8v_1","toolName":"read","content":[{"type":"text","text":"/**\n * 番茄小说多账号多作品配置\n * \n * 支持多个番茄账号，每个账号有多部作品\n * 每部作品每天自动发布2章\n */\n\nconst ACCOUNTS = [\n  {\n    id: 'account_1',\n    name: '主账号',\n    browserDir: '/workspace/projects/browser/fanqie-account-1',\n    works: [\n      { index: 1, name: '作品1' },\n      { index: 2, name: '作品2' },\n      { index: 3, name: '作品3' },\n    ]\n  },\n  {\n    id: 'account_2',\n    name: '小号',\n    browserDir: '/workspace/projects/browser/fanqie-account-2',\n    works: [\n      { index: 1, name: '小号作品1' },\n      { index: 2, name: '小号作品2' },\n    ]\n  },\n];\n\n// 发布配置\nconst PUBLISH_CONFIG = {\n  // 每部作品每天发布的章节数\n  chaptersPerWork: 2,\n  \n  // 章节发布间隔（分钟）\n  chapterInterval: 10,\n  \n  // 作品发布间隔（分钟）\n  workInterval: 30,\n  \n  // 账号发布间隔（分钟）\n  accountInterval: 60,\n};\n\nmodule.exports = { ACCOUNTS, PUBLISH_CONFIG };\n"}],"isError":false,"timestamp":1773806351248}}
