{"type":"message","id":"577d250a","parentId":"600aad4a","timestamp":"2026-03-13T09:02:30.891Z","message":{"role":"toolResult","toolCallId":"call_function_mre1z1nv0spp_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * 番茄小说获取作品 - 超简单版本\n * \n * 直接使用共享浏览器，自动恢复登录状态\n */\n\nconst { chromium } = require('playwright');\n\nconst BROWSER_DIR = '/workspace/projects/browser/default';\nconst BACKUP_FILE = '/workspace/projects/cookies-accounts/fanqie-default-full.json';\n\nasync function getWorks() {\n  const fs = require('fs');\n  \n  // 启动共享浏览器\n  const browser = await chromium.launchPersistentContext(BROWSER_DIR, {\n    headless: true,\n    viewport: null,\n    args: ['--no-sandbox']\n  });\n  \n  const page = browser.pages()[0] || await browser.newPage();\n  \n  // 如果有备份文件，恢复登录状态\n  if (fs.existsSync(BACKUP_FILE)) {\n    const backup = JSON.parse(fs.readFileSync(BACKUP_FILE, 'utf-8'));\n    \n    // 先访问番茄首页\n    await page.goto('https://fanqienovel.com', { waitUntil: 'domcontentloaded' });\n    await page.waitForTimeout(1000);\n    \n    // 恢复 localStorage\n    if (backup.localStorage) {\n      await page.evaluate((items) => {\n        for (const [key, value] of Object.entries(items)) {\n          localStorage.setItem(key, value);\n        }\n      }, backup.localStorage);\n    }\n    \n    // 恢复 cookies\n    if (backup.cookies) {\n      await browser.addCookies(backup.cookies);\n    }\n  }\n  \n  // 访问作品管理页\n  await page.goto('https://fanqienovel.com/main/writer/book-manage', { waitUntil: 'networkidle' });\n  await page.waitForTimeout(3000);\n  \n  // 提取作品\n  const works = await page.evaluate(() => {\n    const results = [];\n    document.querySelectorAll('[class*=\"book\"], [class*=\"work\"], [class*=\"BookItem\"], [class*=\"WorkItem\"]').forEach(el => {\n      const titleEl = el.querySelector('[class*=\"title\"], [class*=\"name\"], h3, h4, [class*=\"Title\"]');\n      if (titleEl) {\n        let title = titleEl.innerText.trim().split('\\n')[0];\n        if (title && title.length > 2 && !title.includes('小贴士') && !title.includes('创建')) {\n          results.push({ title });\n        }\n      }\n    });\n    \n    // 去重\n    const seen = new Set();\n    return results.filter(w => {\n      if (seen.has(w.title)) return false;\n      seen.add(w.title);\n      return true;\n    });\n  });\n  \n  await browser.close();\n  \n  // 输出 JSON\n  const result = {\n    success: true,\n    platform: 'fanqie',\n    count: works.length,\n    works: works,\n    message: works.length > 0 ? `找到 ${works.length} 部作品` : '未找到作品，请检查登录状态'\n  };\n  \n  console.log(JSON.stringify(result));\n  return result;\n}\n\ngetWorks().catch(e => {\n  console.log(JSON.stringify({ success: false, error: e.message }));\n  process.exit(1);\n});\n"}],"isError":false,"timestamp":1773392550832}}
