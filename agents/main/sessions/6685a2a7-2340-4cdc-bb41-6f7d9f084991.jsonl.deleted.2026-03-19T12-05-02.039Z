{"type":"message","id":"3b288f88","parentId":"9f4b62d7","timestamp":"2026-03-18T12:04:04.432Z","message":{"role":"toolResult","toolCallId":"019d00d4def03a133a30655069f1600f","toolName":"read","content":[{"type":"text","text":"/**\n * 智能网页自动化核心模块\n * \n * 提供智能元素查找、自愈机制、状态验证等底层能力\n * 所有网页自动化脚本都应该使用此模块\n */\n\nconst { chromium } = require('playwright');\n\n// ============================================================\n// 配置常量\n// ============================================================\n\nconst DEFAULT_CONFIG = {\n  elementTimeout: 5000,      // 元素查找超时\n  retryCount: 3,             // 默认重试次数\n  retryDelay: 2000,          // 重试间隔\n  navigationTimeout: 30000,  // 导航超时\n};\n\n// ============================================================\n// 智能元素查找\n// ============================================================\n\n/**\n * 智能元素查找 - 多策略备用\n * @param {Page} page - Playwright page对象\n * @param {Array<Function>} strategies - 查找策略数组，每个函数接收page返回locator\n * @param {Object} options - 选项\n * @returns {Locator|null} - 找到的元素或null\n */\nasync function smartLocator(page, strategies, options = {}) {\n  const { timeout = DEFAULT_CONFIG.elementTimeout, visible = true } = options;\n  const startTime = Date.now();\n  \n  while (Date.now() - startTime < timeout) {\n    for (let i = 0; i < strategies.length; i++) {\n      try {\n        const locator = strategies[i](page);\n        const count = await locator.count();\n        \n        if (count > 0) {\n          if (!visible) return locator.first();\n          if (await locator.first().isVisible()) {\n            return locator.first();\n          }\n        }\n      } catch (e) {\n        // 策略失败，尝试下一个\n        continue;\n\n[365 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1773835444430}}
