{"type":"message","id":"ab3f9f92","parentId":"0de9818c","timestamp":"2026-03-18T12:19:31.910Z","message":{"role":"toolResult","toolCallId":"019d00e30583fd96bf5e9ea9716cf236","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * 发布到番茄 - 完整独立版\n * \n * 用法：node bin/publish-to-fanqie.js [作品序号]\n * 示例：node bin/publish-to-fanqie.js 1\n */\n\nconst { chromium } = require('playwright');\nconst fs = require('fs');\nconst path = require('path');\nconst { execSync } = require('child_process');\nconst { recordAction, showLastAction } = require('../core/utils/record');\n\n// 引入智能自动化底层模块\nconst Smart = require('../utils/smart-automation');\n\n// 引入飞书通知\nlet FeishuNotifier;\ntry {\n  const notifier = require('../core/notification/FeishuNotifier');\n  FeishuNotifier = notifier.FeishuNotifier;\n} catch (e) {\n  console.log('  ⚠ 飞书通知模块未加载');\n}\n\n// 数据库路径（用于检查审核状态）\nconst DB_PATH = path.join(__dirname, '../data/chapters.db');\n\n// 数据库连接缓存\nlet dbCache = null;\n\n/**\n * 获取数据库连接（使用 node-sqlite3-wasm，带重试）\n */\nfunction getDb(retryCount = 0) {\n  if (!dbCache) {\n    const { Database } = require('node-sqlite3-wasm');\n    if (!fs.existsSync(DB_PATH)) {\n      return null;\n    }\n    try {\n      dbCache = new Database(DB_PATH, { readonly: true });\n    } catch (e) {\n      if (e.message.includes('database is locked') && retryCount < 5) {\n        console.log(`  数据库被锁定，${(retryCount + 1) * 2}秒后重试...`);\n        // 同步等待（简单实现）\n        const start = Date.now();\n        while (Date.now() - start < (retryCount + 1) * 2000) {}\n        return getDb(retryCount + 1);\n      }\n      throw e;\n    }\n  }\n  return dbCache;\n}\n\n/**\n * 关闭数据库连接\n */\nfunction closeDb() {\n  if (dbCache) {\n    dbCache.close();\n    dbCache = null;\n  }\n}\n\n/**\n * 检查章节审核状态（使用 sqlite3 命令行）\n */\nfunction checkAuditStatus(workName, chapterNum) {\n  try {\n    // 使用 sqlite3 命令行查询 work_id\n    const workIdCmd = `sqlite3 \"${DB_PATH}\" \"SELECT work_id FROM works WHERE work_name = '${workName}';\"`;\n    const workId = execSync(workIdCmd, { encoding: 'utf8' }).trim();\n    \n    if (!workId) {\n      return { passed: false, error: '作品不存在' };\n    }\n    \n    // 查询章节审核状态\n    const auditCmd = `sqlite3 \"${DB_PATH}\" \"SELECT audit_status FROM chapters WHERE work_id = '${workId}' AND chapter_num = ${chapterNum};\"`;\n    const result = execSync(auditCmd, { encoding: 'utf8' }).trim();\n    \n    if (result === 'passed') {\n      return { passed: true };\n    } else if (result === 'failed') {\n      return { passed: false, error: '审核未通过' };\n    } else if (result === 'pending') {\n      return { passed: false, error: '审核中，请等待' };\n    } else {\n      return { passed: false, error: '未审核或状态未知' };\n    }\n  } catch (e) {\n    return { passed: false, error: e.message };\n  }\n}\n\n// ============================================================\n// 配置常量（可修改）\n\n[1355 more lines in file. Use offset=101 to continue.]"}],"isError":false,"timestamp":1773836371907}}
{"type":"message","id":"7423d407","parentId":"ab3f9f92","timestamp":"2026-03-18T12:19:34.225Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"脚本存在，看起来是一个完整的番茄发布脚本。让我继续查看脚本的更多内容，特别是主要功能部分：","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"019d00e30c8c46f366fde673da835451","name":"exec","arguments":{"command":"cd /workspace/projects/auto-scripts/task-planner && node -e \"console.log('Node.js 环境检查通过'); console.log('版本:', process.version); console.log('工作目录:', process.cwd());\""}},{"type":"toolCall","id":"019d00e30f37c3228ca6adaf0a704d84","name":"read","arguments":{"file_path":"/workspace/projects/auto-scripts/task-planner/scripts/auto-publish-all.js","offset":1}}],"api":"openai-completions","provider":"coze","model":"auto","usage":{"input":1897,"output":126,"cacheRead":24128,"cacheWrite":0,"totalTokens":26151,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773836371910}}
{"type":"message","id":"078f3ba6","parentId":"7423d407","timestamp":"2026-03-18T12:19:34.292Z","message":{"role":"toolResult","toolCallId":"019d00e30c8c46f366fde673da835451","toolName":"exec","content":[{"type":"text","text":"Node.js 环境检查通过\n版本: v24.13.1\n工作目录: /workspace/projects/auto-scripts/task-planner"}],"details":{"status":"completed","exitCode":0,"durationMs":54,"aggregated":"Node.js 环境检查通过\n版本: v24.13.1\n工作目录: /workspace/projects/auto-scripts/task-planner","cwd":"/workspace/projects/workspace"},"isError":false,"timestamp":1773836374288}}
{"type":"message","id":"8ba03589","parentId":"078f3ba6","timestamp":"2026-03-18T12:19:34.296Z","message":{"role":"toolResult","toolCallId":"019d00e30f37c3228ca6adaf0a704d84","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * 番茄多账号多作品自动发布\n * \n * 每天为所有账号的所有作品自动发布2章\n * 用法：node bin/auto-publish-all.js\n */\n\nconst { execSync } = require('child_process');\nconst path = require('path');\nconst fs = require('fs');\nconst { ACCOUNTS, PUBLISH_CONFIG } = require('../config/fanqie-accounts');\n\n// 引入飞书通知\nlet FeishuNotifier;\ntry {\n  const notifier = require('../core/notification/FeishuNotifier');\n  FeishuNotifier = notifier.FeishuNotifier;\n} catch (e) {\n  console.log('⚠ 飞书通知模块未加载');\n}\n\nconst sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));\n\n/**\n * 执行单作品发布\n */\nasync function publishWork(account, work, chapterNum) {\n  const publishScript = path.join(__dirname, 'publish-to-fanqie.js');\n  const browserDir = path.resolve(account.browserDir);\n  \n  console.log(`\\n📖 [${account.name}] ${work.name} - 第${chapterNum}章`);\n  console.log(`   浏览器: ${browserDir}`);\n  \n  try {\n    // 设置环境变量指定浏览器目录\n    const env = {\n      ...process.env,\n      FANQIE_BROWSER_DIR: browserDir,\n    };\n    \n    execSync(`node \"${publishScript}\" ${work.index}`, {\n      stdio: 'inherit',\n      timeout: 10 * 60 * 1000, // 10分钟超时\n      env,\n    });\n    \n    return {\n      account: account.name,\n      work: work.name,\n      chapter: chapterNum,\n      status: 'success',\n      time: new Date().toISOString(),\n    };\n  } catch (e) {\n    return {\n      account: account.name,\n      work: work.name,\n      chapter: chapterNum,\n      status: 'failed',\n      error: e.message,\n      time: new Date().toISOString(),\n    };\n  }\n}\n\n/**\n * 发送通知\n */\nasync function sendNotification(results) {\n  if (!FeishuNotifier || !process.env.FEISHU_APP_ID) {\n    return;\n  }\n  \n  try {\n    const notifier = new FeishuNotifier();\n    \n    const success = results.filter(r => r.status === 'success').length;\n    const failed = results.filter(r => r.status === 'failed').length;\n    \n    const details = results.map(r => {\n      const icon = r.status === 'success' ? '✅' : '❌';\n      return `${icon} [${r.account}] ${r.work} 第${r.chapter}章`;\n    }).join('\\n');\n    \n    await notifier.sendMessage(\n      `📊 番茄自动发布完成\\n\\n` +\n      `✅ 成功: ${success} 章\\n` +\n      `❌ 失败: ${failed} 章\\n` +\n      `⏰ 时间: ${new Date().toLocaleString('zh-CN')}\\n\\n` +\n      `详情:\\n${details}\\n\\n` +\n      `---\\nOpenClaw 自动发布系统`\n    );\n    \n    console.log('\\n📱 通知已发送');\n  } catch (e) {\n    console.log('⚠ 通知发送失败:', e.message);\n  }\n}\n\n/**\n * 主流程\n */\nasync function main() {\n  console.log('\\n' + '='.repeat(60));\n  console.log('🚀 番茄多账号自动发布任务');\n  console.log('='.repeat(60));\n  \n  console.log(`\\n📋 配置:`);\n  console.log(`   账号数量: ${ACCOUNTS.length}`);\n  console.log(`   每账号作品: ${ACCOUNTS.map(a => a.works.length).join(', ')}`);\n  console.log(`   每作品每天: ${PUBLISH_CONFIG.chaptersPerWork}章`);\n  console.log(`   章节间隔: ${PUBLISH_CONFIG.chapterInterval}分钟`);\n  console.log(`   作品间隔: ${PUBLISH_CONFIG.workInterval}分钟`);\n  console.log(`   账号间隔: ${PUBLISH_CONFIG.accountInterval}分钟\\n`);\n  \n  // 计算总章节数\n  const totalWorks = ACCOUNTS.reduce((sum, a) => sum + a.works.length, 0);\n  const totalChapters = totalWorks * PUBLISH_CONFIG.chaptersPerWork;\n  \n  console.log(`📊 预计发布: ${totalChapters} 章\\n`);\n  \n  const results = [];\n  let completedCount = 0;\n  \n  // 遍历所有账号\n  for (let accountIndex = 0; accountIndex < ACCOUNTS.length; accountIndex++) {\n    const account = ACCOUNTS[accountIndex];\n    \n    console.log(`\\n${'='.repeat(60)}`);\n    console.log(`👤 [${accountIndex + 1}/${ACCOUNTS.length}] 账号: ${account.name}`);\n    console.log(`${'='.repeat(60)}`);\n    \n    // 确保浏览器目录存在\n    if (!fs.existsSync(account.browserDir)) {\n      fs.mkdirSync(account.browserDir, { recursive: true });\n      console.log(`   创建浏览器目录: ${account.browserDir}`);\n    }\n    \n    // 遍历该账号的所有作品\n    for (let workIndex = 0; workIndex < account.works.length; workIndex++) {\n      const work = account.works[workIndex];\n      \n      console.log(`\\n📚 [${workIndex + 1}/${account.works.length}] 作品: ${work.name}`);\n      \n      // 发布配置的章节数\n      for (let chapterNum = 1; chapterNum <= PUBLISH_CONFIG.chaptersPerWork; chapterNum++) {\n        completedCount++;\n        \n        console.log(`\\n📝 进度: ${completedCount}/${totalChapters} 章`);\n        \n        const result = await publishWork(account, work, chapterNum);\n        results.push(result);\n        \n        // 章节间隔（如果不是最后一个章节）\n        if (chapterNum < PUBLISH_CONFIG.chaptersPerWork) {\n          console.log(`⏳ 等待 ${PUBLISH_CONFIG.chapterInterval} 分钟...`);\n          await sleep(PUBLISH_CONFIG.chapterInterval * 60 * 1000);\n        }\n      }\n      \n      // 作品间隔（如果不是最后一个作品）\n      if (workIndex < account.works.length - 1) {\n        console.log(`⏳ 作品间隔，等待 ${PUBLISH_CONFIG.workInterval} 分钟...`);\n        await sleep(PUBLISH_CONFIG.workInterval * 60 * 1000);\n      }\n    }\n    \n    // 账号间隔（如果不是最后一个账号）\n    if (accountIndex < ACCOUNTS.length - 1) {\n      console.log(`⏳ 账号间隔，等待 ${PUBLISH_CONFIG.accountInterval} 分钟...`);\n      await sleep(PUBLISH_CONFIG.accountInterval * 60 * 1000);\n    }\n  }\n  \n  // 打印汇总\n  console.log('\\n' + '='.repeat(60));\n  console.log('📊 发布任务完成');\n  console.log('='.repeat(60));\n  \n  const success = results.filter(r => r.status === 'success').length;\n  const failed = results.filter(r => r.status === 'failed').length;\n  \n  console.log(`\\n✅ 成功: ${success} 章`);\n  console.log(`❌ 失败: ${failed} 章`);\n  console.log(`📊 总计: ${results.length} 章`);\n  \n  // 打印失败详情\n  const failedResults = results.filter(r => r.status === 'failed');\n  if (failedResults.length > 0) {\n    console.log(`\\n❌ 失败详情:`);\n    failedResults.forEach(r => {\n      console.log(`   [${r.account}] ${r.work} 第${r.chapter}章: ${r.error}`);\n    });\n  }\n  \n  // 发送通知\n  await sendNotification(results);\n  \n  console.log('\\n✅ 任务结束\\n');\n  \n  // 如果有失败，返回错误码\n  if (failed > 0) {\n    process.exit(1);\n  }\n}\n\nmain().catch(e => {\n  console.error('\\n✗ 任务失败:', e.message);\n  process.exit(1);\n});\n"}],"isError":false,"timestamp":1773836374292}}
