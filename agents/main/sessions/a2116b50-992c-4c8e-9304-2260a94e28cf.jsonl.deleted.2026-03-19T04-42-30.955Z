{"type":"message","id":"35475ebb","parentId":"7a5a118d","timestamp":"2026-03-18T04:42:32.452Z","message":{"role":"toolResult","toolCallId":"call_function_s58an1w4o6m3_1","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env node\n/**\n * 番茄多账号多作品自动发布\n * \n * 每天为所有账号的所有作品自动发布2章\n * 用法：node bin/auto-publish-all.js\n */\n\nconst { execSync } = require('child_process');\nconst path = require('path');\nconst fs = require('fs');\nconst { ACCOUNTS, PUBLISH_CONFIG } = require('../config/fanqie-accounts');\n\n// 引入飞书通知\nlet FeishuNotifier;\ntry {\n  const notifier = require('../core/notification/FeishuNotifier');\n  FeishuNotifier = notifier.FeishuNotifier;\n} catch (e) {\n  console.log('⚠ 飞书通知模块未加载');\n}\n\nconst sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));\n\n/**\n * 执行单作品发布\n */\nasync function publishWork(account, work, chapterNum) {\n  const publishScript = path.join(__dirname, 'publish-to-fanqie.js');\n  const browserDir = path.resolve(account.browserDir);\n  \n  console.log(`\\n📖 [${account.name}] ${work.name} - 第${chapterNum}章`);\n  console.log(`   浏览器: ${browserDir}`);\n  \n  try {\n    // 设置环境变量指定浏览器目录\n    const env = {\n      ...process.env,\n      FANQIE_BROWSER_DIR: browserDir,\n    };\n    \n    execSync(`node \"${publishScript}\" ${work.index}`, {\n      stdio: 'inherit',\n      timeout: 10 * 60 * 1000, // 10分钟超时\n      env,\n    });\n    \n    return {\n      account: account.name,\n      work: work.name,\n\n[162 more lines in file. Use offset=51 to continue.]"}],"isError":false,"timestamp":1773808952441}}
